<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Fanuc S-420iW - generated from RoboDK .robot -->
  <xacro:macro name="s_420iw" params="prefix parent *origin">

