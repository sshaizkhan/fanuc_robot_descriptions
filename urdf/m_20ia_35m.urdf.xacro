<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="m_20ia_35m">
  <xacro:arg name="prefix" default=""/>
  <xacro:include filename="$(find fanuc_robot_description)/urdf/m_20ia_35m_macro.xacro"/>
  <link name="world"/>
  <xacro:m_20ia_35m prefix="$(arg prefix)" parent="world">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:m_20ia_35m>
</robot>
