<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Fanuc M-1000iA - generated from RoboDK .robot -->
  <xacro:macro name="m_1000ia" params="prefix parent *origin">

