<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="r_2000ic_270f">
  <xacro:arg name="prefix" default=""/>
  <xacro:include filename="$(find fanuc_robot_descriptions)/urdf/r_2000ic_270f_macro.xacro"/>
  <link name="world"/>
  <xacro:r_2000ic_270f prefix="$(arg prefix)" parent="world">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:r_2000ic_270f>
</robot>
