<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="m_1ia_0_5sl">
  <xacro:arg name="prefix" default=""/>
  <xacro:include filename="$(find fanuc_robot_description)/urdf/m_1ia_0_5sl_macro.xacro"/>
  <link name="world"/>
  <xacro:m_1ia_0_5sl prefix="$(arg prefix)" parent="world">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:m_1ia_0_5sl>
</robot>
