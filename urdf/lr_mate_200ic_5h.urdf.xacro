<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lr_mate_200ic_5h">
  <xacro:arg name="prefix" default=""/>
  <xacro:include filename="$(find fanuc_robot_description)/urdf/lr_mate_200ic_5h_macro.xacro"/>
  <link name="world"/>
  <xacro:lr_mate_200ic_5h prefix="$(arg prefix)" parent="world">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:lr_mate_200ic_5h>
</robot>
